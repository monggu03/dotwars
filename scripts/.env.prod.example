# ─────────────────────────────────────────────────────────────────────
# .env.prod.example — 운영 환경변수 템플릿
#
# 실제 사용 절차:
#  1. EC2 의 /home/ec2-user/app/config/.env.prod 에 이 내용을 복사
#  2. 각 값을 실제 값으로 채움
#  3. chmod 600 /home/ec2-user/app/config/.env.prod
#     (이 파일을 다른 OS 사용자가 못 읽게 — 토큰/비밀번호 보호)
#
# 이 example 파일은 git 에 올라감 (값은 placeholder).
# 실제 .env.prod 는 .gitignore 에 이미 등록 (*.env, .env.*).
# ─────────────────────────────────────────────────────────────────────

# MySQL — docker-compose.prod.yml 의 MYSQL_ROOT_PASSWORD 와 일치해야 함.
# 생성: openssl rand -base64 32
MYSQL_ROOT_PASSWORD=CHANGE_ME_PRODUCTION_DB_PASSWORD

# 카카오 디벨로퍼스 → 앱 키 → REST API 키
KAKAO_CLIENT_ID=CHANGE_ME

# 카카오 디벨로퍼스 → 보안 → Client Secret
KAKAO_CLIENT_SECRET=CHANGE_ME

# 운영 콜백 URL (https + dotwars.kr).
# 카카오 디벨로퍼스의 Redirect URI 등록값과 완전히 일치해야 함.
KAKAO_REDIRECT_URI=https://dotwars.kr/api/auth/kakao/callback

# JWT 서명용 시크릿 (base64 인코딩, 최소 32 bytes = 256 bits).
# 로컬 application-secret.yml 의 시크릿과 같은 값일 필요 X.
# 운영에서 새로 생성하면 기존 토큰 모두 무효화 (사용자 재로그인 필요) → 신규 배포 시점에 OK.
# 생성: openssl rand -base64 64
JWT_SECRET=CHANGE_ME_64_BYTE_BASE64_RANDOM
