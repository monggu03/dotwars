# ─────────────────────────────────────────────────────────────────────
# application-secret.yml.example
#
# 이 파일은 "템플릿". git에 올라가는 안내용 샘플임.
# 실제 사용 절차:
#   1. 같은 폴더에 application-secret.yml 로 복사
#   2. 아래 CHANGE_ME 들을 진짜 값으로 교체
#   3. application-secret.yml 은 .gitignore 에 등록되어 있어 자동으로 추적되지 않음
#
# application.yml 의 spring.config.import 설정으로 자동 로드됨.
# 운영 환경(EC2 등)에서는 이 파일 대신 환경변수로 주입 권장:
#   export KAKAO_CLIENT_ID=...
#   export JWT_SECRET=...
# ─────────────────────────────────────────────────────────────────────

kakao:
  # 카카오 디벨로퍼스 → 내 애플리케이션 → 앱 키 → REST API 키
  client-id: CHANGE_ME
  # 카카오 디벨로퍼스 → 보안 → Client Secret (선택 항목, 사용한다면)
  client-secret: CHANGE_ME
  # 카카오 디벨로퍼스에 등록한 Redirect URI와 정확히 동일해야 함
  redirect-uri: http://localhost:8080/api/auth/kakao/callback

jwt:
  # base64 인코딩된 256bit 이상 시크릿.
  # 생성 예 (PowerShell):
  #   [Convert]::ToBase64String((1..32 | % { Get-Random -Max 256 } | % { [byte]$_ }))
  # 또는 OpenSSL:
  #   openssl rand -base64 32
  secret: CHANGE_ME_TO_BASE64_256BIT
